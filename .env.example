# ============================================
# LegalConnect — Environment Variables
# ============================================
# Copy this file: cp .env.example .env
# Then edit .env with your actual values.

# --- PostgreSQL ---
POSTGRES_USER=legalconnect
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=legalconnect
DATABASE_URL=postgresql://legalconnect:change_me_in_production@localhost:5432/legalconnect

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# --- AI (OVHcloud AI Endpoints — OpenAI-compatible) ---
# OVH AI Endpoints expose an OpenAI-compatible API.
# AI_PROVIDER=openai tells the AI SDK to use the OpenAI client.
# OPENAI_BASE_URL points to the model-specific endpoint from the OVH catalog.
# Catalog: https://www.ovhcloud.com/en/public-cloud/ai-endpoints/catalog/
AI_PROVIDER=openai
AI_MODEL=Qwen/Qwen2.5-72B-Instruct
OPENAI_API_KEY=your-ovh-ai-endpoints-token
OPENAI_BASE_URL=https://qwen2.5-72b-instruct.endpoints.kepler.ai.cloud.ovh.net/api/openai_compat/v1

# --- OVHcloud Object Storage (S3-compatible) ---
OVH_S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
OVH_S3_REGION=gra
OVH_S3_ACCESS_KEY=
OVH_S3_SECRET_KEY=
OVH_S3_BUCKET=legalconnect-documents

# --- Email (Resend) ---
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=LegalConnect <noreply@legalconnect.example.com>

# --- Valkey (Redis-compatible) ---
VALKEY_URL=redis://localhost:6379

# --- Cron ---
# Secret for authenticating cron job endpoints
CRON_SECRET=generate-a-random-secret

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
